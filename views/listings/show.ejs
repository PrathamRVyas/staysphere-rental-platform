<% layout("/layouts/boilerplate") %>

<script>
  const mapToken = "<%= process.env.MAP_TOKEN %>";
  const listing = <%- JSON.stringify(listing) %>;
</script>

<div class="container mt-4">

  <div class="row justify-content-center">
    <div class="col-lg-8 col-12">
      <h3 class="mb-3"><%= listing.title %></h3>
    </div>
  </div>

  <div class="row justify-content-center">
    <div class="col-lg-8 col-12">
      <div class="card show-card listingcard shadow-sm">

    <img src="<%= listing.image.url || listing.image %>"
         class="card-img-top show-img"
         alt="listing_image">

    <div class="card-body">

      <p class="card-text">
        <b>Owned by:</b> <i><%= listing.owner ? listing.owner.username : 'Unknown' %></i>
      </p>

      <p class="card-text"><%= listing.description %></p>

      <p class="card-text">
        &#8377; <%= listing.price?.toLocaleString("en-IN") %>
      </p>

      <p class="card-text">
        <%= listing.location %>, <%= listing.country %>
      </p>

    </div>
  </div>
</div>

  </div>

<% if (currUser && listing.owner && listing.owner._id.equals(currUser._id)) { %> <div class="row justify-content-center mt-3"> <div class="col-lg-8 col-12 d-flex gap-3">

    <a href="/listings/<%= listing._id %>/edit"
       class="btn btn-dark">
      Edit
    </a>

    <form method="POST"
          action="/listings/<%= listing._id %>?_method=DELETE">

      <button class="btn btn-dark">
        Delete
      </button>

    </form>

  </div>
</div>

<% } %>

<% if (currUser) { %> <div class="row justify-content-center mt-4"> <div class="col-lg-8 col-12">

    <hr>
    <h4>Leave a Review</h4>

    <form action="/listings/<%= listing._id %>/reviews"
          method="POST">

      <label class="form-label">Rating</label>

      <fieldset class="starability-slot mb-3">

        <input type="radio" id="rate1"
               name="review[rating]" value="1">
        <label for="rate1">1</label>

        <input type="radio" id="rate2"
               name="review[rating]" value="2">
        <label for="rate2">2</label>

        <input type="radio" id="rate3"
               name="review[rating]" value="3">
        <label for="rate3">3</label>

        <input type="radio" id="rate4"
               name="review[rating]" value="4">
        <label for="rate4">4</label>

        <input type="radio" id="rate5"
               name="review[rating]" value="5">
        <label for="rate5">5</label>

      </fieldset>

      <div class="mb-3">
        <label class="form-label">Comment</label>
        <textarea name="review[comment]"
                  class="form-control"
                  rows="3"
                  required></textarea>
      </div>

      <button class="btn btn-outline-dark">
        Submit
      </button>

    </form>

    <hr>

  </div>
</div>

<% } %>


<% if (listing.reviews.length > 0) { %> <div class="row justify-content-center mt-3"> <div class="col-lg-8 col-12">

    <p><b>All Reviews</b></p>

<% 
  const sentiments = listing.reviews.map(r => r.sentiment).filter(Boolean);
  const posCount = sentiments.filter(s => s === 'Positive').length;
  const negCount = sentiments.filter(s => s === 'Negative').length;
  const neuCount = sentiments.filter(s => s === 'Neutral').length;
  let summaryText = '';
  let summaryClass = '';
  if (sentiments.length > 0) {
    if (posCount > negCount && posCount > neuCount) {
      summaryText = `Insight: Most guests had a positive experience (${posCount} positive, ${neuCount} neutral, ${negCount} negative reviews).`;
      summaryClass = 'text-success';
    } else if (negCount > posCount && negCount > neuCount) {
      summaryText = `Insight: Guests had a mixed experience (${negCount} negative, ${neuCount} neutral, ${posCount} positive reviews).`;
      summaryClass = 'text-danger';
    } else {
      summaryText = `Insight: Guests had a mixed experience (${posCount} positive, ${neuCount} neutral, ${negCount} negative reviews).`;
      summaryClass = 'text-warning';
    }
  }
%>

<% if (summaryText) { %>
  <div class="alert alert-light border mb-3 py-2">
    <small class="<%= summaryClass %>"><b><%= summaryText %></b></small>
  </div>
<% } %>

    <div class="row g-3">

      <% for (let review of listing.reviews) { %>
        <div class="col-md-6 col-12">

          <div class="card h-100 review-card shadow-sm">

            <div class="card-body">

              <h5 class="card-title">
                @<%= review.author.username %>
              </h5>

              <p class="starability-result"
                 data-rating="<%= review.rating %>"></p>

              <p><%= review.comment %></p>

              <% if (review.sentiment) { %>
                  <span class="badge <%=
                  review.sentiment === 'Positive' ? 'bg-success' :
                  review.sentiment === 'Negative' ? 'bg-danger' : 'bg-secondary'
                %>">
                <%=
                  review.sentiment === 'Positive' ? 'Positive' :
                  review.sentiment === 'Negative' ? 'Negative' : 'Neutral'
                %>
  </span>
<% } %>

              <form method="POST"
                    action="/listings/<%= listing._id %>/reviews/<%= review._id %>?_method=DELETE">

                <button class="btn btn-sm btn-dark">
                  Delete
                </form>

            </div>

          </div>

        </div>
      <% } %>

    </div>

  </div>
</div>

<% } %>

  <div class="row justify-content-center mt-4 mb-5">
    <div class="col-lg-8 col-12">

  <h4>Where you'll be</h4>

  <div id="map"
       style="height: 400px; border-radius: 12px;"></div>

</div>

  </div>

</div>

<script src="/js/map.js"></script>