<% layout("/layouts/boilerplate") %>

<div class="row">
  <div class="col-6 offset-3">
  <h3><b>Create New Listing :</b></h3>

  <form method="POST" action="/listings" novalidate class="needs-validation" enctype="multipart/form-data">

    
    <div class="mb-3">
      <label class="form-label" for="title">Title</label>
      <input
        name="listing[title]"
        type="text"
        class="form-control"
        placeholder="Add a catchy title"
        id="title"
        required
      >
      <div class="valid-feedback">Title looks good!</div>
      <div class="invalid-feedback">Invalid Title!</div>
    </div>

    
    <div class="mb-3">
      <label class="form-label" for="desc">Description</label>
      <textarea
        name="listing[description]"
        class="form-control"
        rows="3"
        placeholder="Enter Description"
        id="desc"
        required
      ></textarea>
      <div class="invalid-feedback">Please enter a short description!</div>
      <button type="button" id="generate-desc" class="btn btn-outline-secondary btn-sm mt-1">✨ Generate with AI</button>
    </div>



    <select name="listing[category]" class="form-select" required>
  <option value="Trending">Trending</option>
  <option value="Rooms">Rooms</option>
  <option value="Iconic cities">Iconic Cities</option>
  <option value="Mountains">Mountains</option>
  <option value="Castles">Castles</option>
  <option value="Amazing Pools">Amazing Pools</option>
  <option value="Camping">Camping</option>
  <option value="Farms">Farms</option>
  <option value="Arctic">Arctic</option>
  <option value="Domes">Domes</option>
  <option value="Boats">Boats</option>
  </select>


        <div class="mb-3">
      <label class="form-label" for="img">Upload Listing Image</label>
      <input
        name="listing[image]"
        type="file"
        class="form-control"
        id="img"
        required
      >
    </div>

   <div class="row">
    <div class="mb-3 col-md-4">
      <label class="form-label" for="price">Price</label>
      <input
        name="listing[price]"
        
        class="form-control"
        placeholder="1500"
        id="price"
        required
      >
      <div class="invalid-feedback">Price should be valid!</div>
    </div>

    <div class="mb-3 col-md-8">
      <label class="form-label" for="country">Country</label>
      <input
      name="listing[country]"
      type="text"
      class="form-control"
      placeholder="India"
      id="country"
      required
      >
      <div class="invalid-feedback">Country name should be valid!</div>
    </div>
    
    

    
    <div class="mb-3">
      <label class="form-label" for="loc">Location</label>
      <input
        name="listing[location]"
        type="text"
        class="form-control"
        placeholder="Vadodara, Gujarat"
        id="loc"
        required
      >
      <div class="invalid-feedback">Location should be valid!</div>
    </div>

    
    <button class="btn btn-dark btn-add mb-3">Add</button>
    

  </form>
  </div>
</div>

<script>
  document.getElementById("generate-desc").addEventListener("click", async () => {
    const title = document.getElementById("title").value;
    const location = document.getElementById("loc").value;
    const country = document.getElementById("country").value;
    const category = document.querySelector("select[name='listing[category]']").value;

    const response = await fetch("/ai/generate-description", {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({ title, location, country, category })
    });

    const data = await response.json();
    document.getElementById("desc").value = data.description;
  });
</script>
